{
  "name": "api-hooks",
  "private": true,
  "version": "0.0.0",
  "description": "A collection of React hooks built on @tanstack/react-query for seamless API integration",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "find . -name 'dist' -not -path '*/node_modules/*' -exec rm -rf {} +"
  },
  "devDependencies": {
    "@swc/core": "^1.10.0",
    "@swc/jest": "^0.2.37",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
