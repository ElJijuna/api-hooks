{
  "name": "@api-hooks/bp",
  "version": "1.2.2",
  "description": "React hooks for the Bundlephobia API, built on @tanstack/react-query",
  "keywords": [
    "react",
    "hooks",
    "bundlephobia",
    "bundle-size",
    "react-query",
    "tanstack"
  ],
  "license": "MIT",
  "homepage": "https://github.com/ElJijuna/api-hooks#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElJijuna/api-hooks.git",
    "directory": "packages/bp"
  },
  "bugs": {
    "url": "https://github.com/ElJijuna/api-hooks/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declarationMap",
    "dev": "vite build --watch",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": ">=19.0.0"
  },
  "dependencies": {
    "bundlephobia-api-client": "^1.1.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@testing-library/react": "^16.0.0",
    "bundlephobia-api-client": "^1.1.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8.0.8",
    "typedoc": "^0.28.0",
    "vite-magic-tree-shaking": "^1.0.0"
  }
}
