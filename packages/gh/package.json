{
  "name": "@api-hooks/gh",
  "version": "1.5.0",
  "description": "React hooks for the GitHub API, built on @tanstack/react-query",
  "keywords": [
    "react",
    "hooks",
    "github",
    "api",
    "react-query",
    "tanstack"
  ],
  "license": "MIT",
  "homepage": "https://github.com/ElJijuna/api-hooks#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElJijuna/api-hooks.git",
    "directory": "packages/gh"
  },
  "bugs": {
    "url": "https://github.com/ElJijuna/api-hooks/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@testing-library/react": "^16.0.0",
    "gh-api-client": "^1.5.1",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typedoc": "^0.28.0",
    "vite": "^8.0.8",
    "vite-magic-tree-shaking": "^1.0.0"
  }
}
